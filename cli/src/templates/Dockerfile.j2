{{ header }}#
# =============================================================================
# HOW TO CUSTOMIZE:
#   Do NOT edit this file directly — it is regenerated by `aibox sync`.
#   To add build steps: create Dockerfile.local (appended as the final layer)
#   To pin tool versions: use [addons.<name>.tools] version fields in aibox.toml
#
# KEY VARIABLES (set automatically from aibox.toml):
#   registry  — GHCR base image path (ghcr.io/projectious-work/aibox)
#   image     — base image flavor tag (e.g. base-debian)
#   version   — pinned aibox image version
# =============================================================================
{% for stage in addon_builder_stages %}
{{ stage }}

{% endfor %}
FROM {{ registry }}:{{ image }}-v{{ version }} AS aibox
LABEL aibox.version="{{ version }}"
{% for addon_cmd in addon_commands %}

{{ addon_cmd }}
{% endfor %}
{% if local_content %}

# Project-specific layers (from Dockerfile.local — not managed by aibox sync)
{{ local_content }}
{% endif %}

# Record image version inside container for runtime checks
USER root
RUN echo "{{ version }}" > /etc/aibox-version
